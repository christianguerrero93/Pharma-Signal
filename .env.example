# Pharma Signal environment template

# Frontend
VITE_APP_ENV=local
VITE_API_URL=http://localhost:8001
VITE_ENTERPRISE_API_URL=http://localhost:8080
# Full DSP API that powers the Command OS workbench (src/EnterpriseDSPApp.tsx).
# Local dev: http://localhost:8090. In Netlify, set this to the deployed backend
# URL, e.g. https://pharma-signal-api.onrender.com
VITE_FULL_DSP_API_URL=http://localhost:8090
VITE_FULL_DSP_DEV_PASSWORD=pharma-signal-local

# Full DSP backend (backend/full_dsp_server.py)
FULL_DSP_DEV_PASSWORD=pharma-signal-local
# SQLite path (used when DATABASE_URL is unset). Point at a mounted disk in
# production, e.g. /data/pharma_signal_dsp.db
FULL_DSP_DB=./pharma_signal_dsp.db
# Set DATABASE_URL to use Postgres instead of SQLite.
# DATABASE_URL=postgresql://user:pass@host:5432/pharma_signal
# Secret used to sign HS256 JWTs — set a strong random value in production.
FULL_DSP_JWT_SECRET=pharma-signal-dev-secret-change-me
# JWT lifetime in seconds (default 12h).
FULL_DSP_JWT_TTL=43200
# Refresh-token lifetime in seconds (default 14 days).
FULL_DSP_REFRESH_TTL=1209600
# Login brute-force protection: max failed attempts per window (seconds).
FULL_DSP_LOGIN_RATE_LIMIT=10
FULL_DSP_LOGIN_RATE_WINDOW=300
# CORS allowlist. "*" for local dev, or comma-separated origins to lock down prod,
# e.g. https://pharma-signal.netlify.app
CORS_ORIGINS=*
# Absolute base URL used to build OpenRTB win-notice (nurl) and billing (burl) URLs.
# Set to the deployed API origin so exchanges can reach the callbacks, e.g.
# https://pharma-signal-api.onrender.com
PUBLIC_BASE_URL=
VITE_GA4_PROPERTY_ID=
VITE_GA4_CLIENT_ID=
VITE_WAREHOUSE_PROJECT_ID=
VITE_SUPPLY_QA_ENDPOINT=
VITE_MEASUREMENT_IMPORT_ENDPOINT=
VITE_VERIFICATION_FEED_ENDPOINT=

# Existing backend / Emergent Mongo API
MONGO_URL=mongodb://localhost:27017
DB_NAME=pharma_signal
JWT_SECRET=replace-this-before-production
ADMIN_EMAIL=admin@pharmasignal.io
ADMIN_PASSWORD=Admin@2026
CORS_ORIGINS=*
EMERGENT_LLM_KEY=

# Future production services
POSTGRES_URL=postgresql://pharma_signal:pharma_signal@localhost:5432/pharma_signal
REDIS_URL=redis://localhost:6379/0
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
BIGQUERY_PROJECT_ID=
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_DATABASE=PHARMA_SIGNAL
SNOWFLAKE_SCHEMA=PUBLIC
